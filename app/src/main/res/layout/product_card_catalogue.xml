<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_margin="3dp">

        <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintTop_toTopOf="parent">

            <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:padding="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/ic_product"
                    android:scaleX="1.1"
                    android:scaleY="1.1"/>

            <TextView
                    android:id="@+id/tvName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="32sp"
                    android:textAlignment="center"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/imageView"
                    android:fontFamily="@font/montserrat_regular" />

            <TextView
                    android:id="@+id/tvCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:gravity="center"
                    android:minWidth="40dp"
                    android:text="0"
                    android:textAlignment="center"
                    android:textSize="14sp"
                    app:layout_constraintBottom_toBottomOf="@+id/buttonDecrease"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvBrand"
                    android:fontFamily="@font/montserrat_regular"
                    android:layout_marginTop="6dp"
                    android:visibility="invisible" />

            <Button
                    android:id="@+id/buttonIncrease"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/button_rounded_right"
                    android:gravity="center"
                    android:padding="0dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="6dp"
                    android:text="+"
                    android:textAlignment="center"
                    app:layout_constraintStart_toEndOf="@+id/tvCounter"
                    app:layout_constraintTop_toBottomOf="@+id/tvBrand"
                    android:fontFamily="@font/montserrat_regular"
                    android:visibility="invisible" />

            <Button
                    android:id="@+id/buttonDecrease"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/button_rounded_left"
                    android:gravity="center"
                    android:padding="0dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="6dp"
                    android:text="-"
                    android:textAlignment="center"
                    app:layout_constraintEnd_toStartOf="@+id/tvCounter"
                    app:layout_constraintTop_toBottomOf="@+id/tvBrand"
                    android:fontFamily="@font/montserrat_regular"
                    android:visibility="invisible" />

            <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="6dp"

                    android:textSize="14sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:fontFamily="@font/montserrat_regular"
                    app:layout_constraintTop_toBottomOf="@+id/tvCounter" />

            <TextView
                    android:text=""
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvBrand"
                    app:layout_constraintTop_toBottomOf="@+id/tvName"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:fontFamily="@font/montserrat_regular"
                    android:textSize="14sp"
                    android:textAlignment="center"
                    android:layout_marginTop="6dp"
                    android:textStyle="italic" />

            <ImageButton
                    android:layout_width="120dp"
                    android:layout_height="40dp"
                    android:backgroundTint="?attr/actionModeSplitBackground"
                    android:id="@+id/imageButton"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toTopOf="@+id/tvPrice"
                    app:layout_constraintTop_toBottomOf="@+id/tvBrand"
                    android:padding="0dp"
                    android:background="@drawable/background_rounded_full"
                    android:src="@drawable/ic_add_shopping_cart"
                    android:layout_margin="6dp"
                    android:visibility="visible" />

            <!--            <ImageButton-->
            <!--                android:id="@+id/imageButton"-->
            <!--                android:layout_width="35dp"-->
            <!--                android:layout_height="35dp"-->
            <!--                android:backgroundTint="@android:color/transparent"-->
            <!--                app:layout_constraintEnd_toEndOf="parent"-->
            <!--                app:layout_constraintTop_toTopOf="parent"-->
            <!--                app:srcCompat="@drawable/ic_favorite"-->
            <!--                android:layout_margin="6dp"-->
            <!--                android:padding="0dp"-->
            <!--                android:scaleType="fitXY"/>-->
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>