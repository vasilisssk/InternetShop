<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextInputLayoutTheme">
        <item name="android:layout_width">300dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">5dp</item>
        <item name="android:layout_marginStart">40dp</item>
        <item name="android:layout_marginEnd">40dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="android:fontFamily">@font/montserrat_regular</item>
    </style>

    <style name="TitleTheme">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">40dp</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:fontFamily">@font/montserrat_bold</item>
    </style>

    <style name="TextInputEditTextTheme">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">start</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:fontFamily">@font/montserrat_regular</item>
    </style>

    <style name="ButtonSigningTheme">
        <item name="android:layout_width">240dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:fontFamily">@font/montserrat_regular</item>
        <item name="background">@drawable/background_rounded_full</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SearchViewFont" parent="android:Widget.Material.SearchView">
        <item name="fontFamily">@font/montserrat_regular</item>
    </style>

    <style name="EditTextFont">
        <item name="fontFamily">@font/montserrat_regular</item>
        <item name="android:textColor">@color/icon_color</item>
    </style>

    <style name="SpinnerFont" parent="TextAppearance.AppCompat.Widget.TextView.SpinnerItem">
        <item name="fontFamily">@font/montserrat_regular</item>
    </style>

    <style name="OrangeButton" parent="android:Widget.Button">
        <item name="android:backgroundTint">@color/icon_color</item>
    </style>
</resources>