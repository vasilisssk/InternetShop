<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/catalogueFragment">

    <fragment
        app:route="catalogue"
        android:id="@+id/catalogueFragment"
        android:name="com.game.internetshop.ui.catalogue.CatalogueFragment"
        android:label="Catalogue"
        tools:layout="@layout/fragment_catalogue">
    </fragment>

    <fragment
        app:route="cart"
        android:id="@+id/cartFragment"
        android:name="com.game.internetshop.ui.cart.CartFragment"
        android:label="Cart"
        tools:layout="@layout/fragment_cart">
    </fragment>

    <fragment
        app:route="orders"
        android:id="@+id/ordersFragment"
        android:name="com.game.internetshop.ui.orders.OrdersFragment"
        android:label="Orders"
        tools:layout="@layout/fragment_orders">
